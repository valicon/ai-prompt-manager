# LLM Provider: openai | openrouter | ollama | groq (default: openai)
LLM_PROVIDER=openai

# --- OpenAI (default) ---
OPENAI_KEY=sk-your-openai-api-key
OPENAI_API_URL=https://api.openai.com/v1

# --- OpenRouter (free models at openrouter.ai) ---
# OPENROUTER_API_KEY=sk-or-your-key
# OPENROUTER_API_URL=https://openrouter.ai/api/v1

# --- Ollama (local, no key: ollama run llama3) ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- Groq (free tier at groq.com) ---
# GROQ_API_KEY=gsk_your-key
# GROQ_API_URL=https://api.groq.com/openai/v1

# Optional: Override model for prompt rewriting (e.g., openrouter/free, llama3)
# LLM_REWRITE_MODEL=gpt-4o-mini

# Proxy port
PORT=3000

# Omega memory MCP: 0 = disable idle timeout (prevents connection drops)
OMEGA_IDLE_TIMEOUT=0
